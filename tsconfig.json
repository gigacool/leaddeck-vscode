{
  // The host: Node + vscode, and deliberately NO dom.
  //
  // The webview half is checked by tsconfig.webview.json, which has DOM and no
  // Node. Keeping them apart is what stops `document` from typechecking in the
  // extension host, where it would fail at runtime.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node", "vscode"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["src/surface/webview/**/*.ts"]
}
